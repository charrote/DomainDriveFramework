// ============================================================
// <%= entity.name %> — generated by DDF Engine
// Domain: <%= entity.domain %><% if (entity.description) { %>
// <%= entity.description %><% } %>
// ============================================================

model <%= entity.name %> {
  id          Int      @id @default(autoincrement())
<% entity.fields.forEach(field => { -%>
  <% if (['id','created_by','created_at','updated_at'].includes(field.name)) { -%>
  <% } else { -%>
  <%= field.name.padEnd(16) %> <%= ddfTypeToPrisma(field.type) %><% if (field.required === false) { %>?<% } %><% if (field.unique) { %> @unique<% } %><% if (field.enum && field.type === 'enum') { %> // enum: <%= field.enum %><% } %>
  <% } -%>
<% }) -%>

<% entity.relations.forEach(rel => { -%>
  // Relation: <%= rel.name %> → <%= rel.target %>
<% }) -%>

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("<%= entity.table %>")
}
