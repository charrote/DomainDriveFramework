/**
 * <%= entity.name %> API 服务
 * Generated by DDF Engine
 */

import request from '@/utils/request'

/**
 * 分页列表
 */
export function get<%= entity.name %>List(params) {
  return request({
    url: '/api/<%= toKebab(entity.name) %>',
    method: 'get',
    params,
  })
}

/**
 * 详情
 */
export function get<%= entity.name %>(id) {
  return request({
    url: `/api/<%= toKebab(entity.name) %>/${id}`,
    method: 'get',
  })
}

/**
 * 创建
 */
export function create<%= entity.name %>(data) {
  return request({
    url: '/api/<%= toKebab(entity.name) %>',
    method: 'post',
    data,
  })
}

/**
 * 更新
 */
export function update<%= entity.name %>(id, data) {
  return request({
    url: `/api/<%= toKebab(entity.name) %>/${id}`,
    method: 'put',
    data,
  })
}

/**
 * 删除
 */
export function delete<%= entity.name %>(id) {
  return request({
    url: `/api/<%= toKebab(entity.name) %>/${id}`,
    method: 'delete',
  })
}
