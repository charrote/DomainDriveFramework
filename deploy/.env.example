# ============================================================
# DDF 部署环境变量
# 复制为 .env 并修改
# ============================================================

# JWT 密钥（生产环境必须修改！）
JWT_SECRET=change-me-in-production

# 数据库路径
DATABASE_URL=file:./data/dev.db

# API 基础 URL（前端使用）
VITE_API_BASE_URL=http://localhost:3000
