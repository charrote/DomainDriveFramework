# ============================================================
# DDF 部署环境变量
# 复制为 .env 并修改
# ============================================================

# JWT 密钥（生产环境必须修改！）
JWT_SECRET=change-me-in-production

# ---- PostgreSQL 配置 ----
# 连接串（docker-compose 自动拼接，一般无需修改）
# DATABASE_URL=postgresql://ddf:ddf_secret@postgres:5432/ddf
PG_USER=ddf
PG_PASSWORD=ddf_secret
PG_DATABASE=ddf

# ---- SQLite 配置（本地开发用，Docker 下使用 PostgreSQL） ----
# DATABASE_URL=file:./data/dev.db

# API 基础 URL（前端使用）
VITE_API_BASE_URL=http://localhost:3000
