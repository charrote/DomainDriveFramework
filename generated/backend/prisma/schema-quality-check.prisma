// ============================================================
// QualityCheck — generated by DDF Engine
// Domain: base.quality_check
// ============================================================

model QualityCheck {
  id          Int      @id @default(autoincrement())
        check_no         String
      work_order_no    Int
      production_record_id Int
      check_type       String
      check_name       String
      inspection_item_id Int
      sample_size      Int
      measured_value   Float
      tolerance_min    Float
      tolerance_max    Float
      result           String
      defect_id        Int
      inspector_id     Int
      check_time       DateTime
      remark           String
          
  // Relation: work_order → WorkOrder
  // Relation: inspector → User

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("quality_check")
}
