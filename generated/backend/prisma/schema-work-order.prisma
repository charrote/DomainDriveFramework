// ============================================================
// WorkOrder — generated by DDF Engine
// Domain: base.work_order
// ============================================================

model WorkOrder {
  id          Int      @id @default(autoincrement())
    order_no         String
      product_code     String
      product_name     String
      quantity         Int
      completed_quantity Int
      scrap_quantity   Int
      status           String
      priority         String
      plan_start_date  DateTime
      plan_end_date    DateTime
      actual_start_time DateTime
      actual_end_time  DateTime
      route_id         Int
      production_line_id Int
      shift_id         Int
      comment          String
              
  // Relation: bom_items → WOBOMItem
  // Relation: production_records → ProductionRecord
  // Relation: quality_checks → QualityCheck
  // Relation: creator → User
  // Relation: production_line → ProductionLine

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("work_order")
}
