// ============================================================
// Container — generated by DDF Engine
// Domain: base.container
// ============================================================

model Container {
  id          Int      @id @default(autoincrement())
        container_code   String @unique
      container_name   String
      container_type   String
      status           String
      max_weight_kg    Float
      device_id        Int
      workstation_id   Int
          
  // Relation: device → Device

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("container")
}
