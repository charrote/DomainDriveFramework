// ============================================================
// User — generated by DDF Engine
// Domain: base.user
// ============================================================

model User {
  id          Int      @id @default(autoincrement())
        username         String @unique
      real_name        String
      password_hash    String
      role             String
      status           String
          

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("sys_user")
}
