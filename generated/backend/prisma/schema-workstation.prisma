model Workstation {
  id          Int      @id @default(autoincrement())
        station_code     String
      station_name     String
      production_line_id Int
      status           String
          
  // Relation: production_line → ProductionLine
  // Relation: devices → Device

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("workstation")
}
