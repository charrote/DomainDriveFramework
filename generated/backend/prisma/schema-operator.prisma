// ============================================================
// Operator — generated by DDF Engine
// Domain: base.operator
// ============================================================

model Operator {
  id          Int      @id @default(autoincrement())
        operator_no      String @unique
      operator_name    String
      user_id          Int
      production_line_id Int
      shift_id         Int
      skill_level      String
      status           String
      phone            String
      hire_date        DateTime
          
  // Relation: production_line → ProductionLine
  // Relation: shift → Shift

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("operator")
}
