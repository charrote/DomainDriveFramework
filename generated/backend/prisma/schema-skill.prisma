// ============================================================
// Skill — generated by DDF Engine
// Domain: base.skill
// ============================================================

model Skill {
  id          Int      @id @default(autoincrement())
        skill_code       String @unique
      skill_name       String
      category         String
      description      String
      status           String
      

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("skill")
}
