model InspectionPlan {
  id          Int      @id @default(autoincrement())
        plan_code        String @unique
      plan_name        String
      check_type       String
      batch_min        Int
      batch_max        Int
      sample_size      Int
      accept_limit     Int
      reject_limit     Int
      severity         String
      status           String
      

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("inspection_plan")
}
