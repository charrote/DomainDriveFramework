// ============================================================
// BOMItem — generated by DDF Engine
// Domain: base.bom
// ============================================================

model BOMItem {
  id          Int      @id @default(autoincrement())
        product_bom_id   Int
      material_code    String
      material_name    String
      quantity         Float
      unit             String
      scrap_rate       Float
      parent_item_id   Int
      
  // Relation: product_bom → ProductBOM

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("bom_item")
}
