// ============================================================
// Device — generated by DDF Engine
// Domain: base.device
// ============================================================

model Device {
  id          Int      @id @default(autoincrement())
        device_code      String @unique
      device_name      String
      device_type      String
      category_id      Int
      model            String
      production_line_id Int
      workstation_id   Int
      status           String
      purchase_date    DateTime
      last_maintenance_date DateTime
          
  // Relation: production_line → ProductionLine

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("device")
}
