model Shift {
  id          Int      @id @default(autoincrement())
        shift_code       String
      shift_name       String
      start_time       String
      end_time         String
      shift_date       DateTime
      shift_pattern_id Int
      

  created_by  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("shift")
}
